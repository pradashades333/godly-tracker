EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_ENV=production
# Choose the marketplace you want to search. For euro pricing, Germany is a sensible default.
EBAY_MARKETPLACE_ID=EBAY_DE
# Optional: local folder used for MM2 item images.
MM2_IMAGE_DIR=C:\Files\woblox\random images
